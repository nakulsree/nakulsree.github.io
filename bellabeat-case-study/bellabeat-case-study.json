  "key_findings": {
    "r2_intensity_vs_calories": 0.80,
    "r2_steps_vs_calories": 0.66,
    "pct_moderate_plus_active": 2.85,
    "aha_recommended_pct": 3.0,
    "pct_light_sedentary": 97.15,
    "active_minutes_breakdown": {
      "light": 84.74,
      "moderate": 5.96,
      "intense": 9.30
    },
    "peak_days": ["Tuesday", "Saturday"],
    "low_days": ["Sunday", "Thursday"],
    "peak_hours": "17:00-19:00",
    "activity_dip": "14:00-15:00"
  },
  "recommendations": [
    "Leaf product: notify users when intensity is too low for extended periods",
    "Bellabeat app: celebrate users reaching 2.85% (average) and 3% (AHA goal) active time milestones",
    "Sunday/Thursday: send motivational reminders to increase workout duration and intensity",
    "2 PM: send targeted motivational prompt to combat the daily afternoon activity dip"
  ],
